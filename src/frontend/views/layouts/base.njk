<!DOCTYPE html>
<html lang="en" class="govuk-template">
  <head>
    <meta charset="utf-8" />
    <title>{% block pageTitle %}Caseworker Task Manager{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0b0c0c" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="stylesheet" href="/public/css/app.css" />
  </head>
  <body class="govuk-template__body">
    <script>
      document.body.className += ' js-enabled' + ('noModule' in HTMLScriptElement.prototype ? ' govuk-frontend-supported' : '');
    </script>

    <a href="#main-content" class="govuk-skip-link" data-module="govuk-skip-link">Skip to main content</a>

    <header class="govuk-header" data-module="govuk-header">
      <div class="govuk-header__container govuk-width-container">
        <div class="govuk-header__content">
          <a href="/" class="govuk-header__link govuk-header__service-name">
            Caseworker Task Manager for Developer Technical Test - Not an official website!
          </a>
        </div>
      </div>
    </header>

    <div class="govuk-width-container">
      <main class="govuk-main-wrapper" id="main-content" role="main">
        {% block content %}{% endblock %}
      </main>
    </div>

    <footer class="govuk-footer" role="contentinfo">
      <div class="govuk-width-container">
        <div class="govuk-footer__meta">
          <div class="govuk-footer__meta-item govuk-footer__meta-item--grow">
            <span class="govuk-footer__licence-description">
              This is not an official government service, this is a simple Task Management Tool for DTS Developer Technical Test that uses GOV.UK Design System.
            </span>
          </div>
        </div>
      </div>
    </footer>

    <script type="module" src="/vendor/govuk/govuk-frontend.min.js"></script>
    <script type="module">
      import { initAll } from '/vendor/govuk/govuk-frontend.min.js';
      initAll();
    </script>
    <script defer src="/vendor/alpine/cdn.min.js"></script>
    <script src="/public/js/task-manager.js"></script>
  </body>
</html>
